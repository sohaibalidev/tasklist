{
  "expo": {
    "name": "Todo App",
    "slug": "todo-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "cover",
      "backgroundColor": "#F6F1E9"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.sohaibalidev.todoapp"
    },
    "android": {
      "package": "com.sohaibalidev.todoapp",
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#ffffff"
      }
    },
    "plugins": [
      "expo-router",
      [
        "expo-build-properties",
        {
          "ios": {
            "useFrameworks": "static"
          }
        }
      ],
      "expo-web-browser",
      "expo-secure-store",
      "@react-native-google-signin/google-signin",
      "expo-font"
    ],
    "scheme": "com.sohaibalidev.todoapp",
    "extra": {
      "router": {},
      "eas": {
        "projectId": "0942279e-b3d8-4c4b-9393-73abfe440978"
      }
    }
  }
}